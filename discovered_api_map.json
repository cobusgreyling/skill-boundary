{
  "api": {
    "api": "DevForge Platform API",
    "version": "v2",
    "resources": [
      "secrets",
      "deployments",
      "environments",
      "pipelines",
      "audit-log",
      "users",
      "webhooks",
      "repos"
    ]
  },
  "endpoints": {
    "audit-log": {
      "/audit-log": {
        "GET": {
          "description": "Query audit log",
          "parameters": [
            "actor",
            "action",
            "resource",
            "date_from",
            "date_to"
          ],
          "auth_required": "admin_key",
          "auth_description": "Admin access \u2014 platform administrators only"
        }
      }
    },
    "deployments": {
      "/deployments": {
        "GET": {
          "description": "List deployments",
          "parameters": [
            "repo_id",
            "environment",
            "status",
            "date_from"
          ],
          "auth_required": "api_key",
          "auth_description": "Standard API access \u2014 available to all authenticated developers"
        },
        "POST": {
          "description": "Trigger deployment",
          "parameters": [
            "repo_id",
            "branch",
            "environment",
            "config_overrides"
          ],
          "auth_required": "deploy_key",
          "auth_description": "Deploy access \u2014 CI/CD systems and authorized deployers"
        }
      },
      "/deployments/{id}": {
        "GET": {
          "description": "Get deployment status",
          "parameters": [],
          "auth_required": "api_key",
          "auth_description": "Standard API access \u2014 available to all authenticated developers"
        },
        "DELETE": {
          "description": "Rollback deployment",
          "parameters": [],
          "auth_required": "deploy_key",
          "auth_description": "Deploy access \u2014 CI/CD systems and authorized deployers"
        }
      },
      "/deployments/{id}/logs": {
        "GET": {
          "description": "Get deployment logs",
          "parameters": [
            "level",
            "since"
          ],
          "auth_required": "api_key",
          "auth_description": "Standard API access \u2014 available to all authenticated developers"
        }
      }
    },
    "environments": {
      "/environments": {
        "GET": {
          "description": "List environments",
          "parameters": [
            "repo_id"
          ],
          "auth_required": "api_key",
          "auth_description": "Standard API access \u2014 available to all authenticated developers"
        },
        "POST": {
          "description": "Create environment",
          "parameters": [
            "name",
            "repo_id",
            "protection_rules",
            "variables"
          ],
          "auth_required": "admin_key",
          "auth_description": "Admin access \u2014 platform administrators only"
