        "GET": {
          "description": "Get environment details",
          "parameters": [],
          "auth_required": "api_key",
          "auth_description": "Standard API access \u2014 available to all authenticated developers"
        },
        "PATCH": {
          "description": "Update environment config",
          "parameters": [
            "protection_rules",
            "variables"
          ],
          "auth_required": "admin_key",
          "auth_description": "Admin access \u2014 platform administrators only"
        },
        "DELETE": {
          "description": "Delete environment",
          "parameters": [],
          "auth_required": "admin_key",
          "auth_description": "Admin access \u2014 platform administrators only"
        }
      }
    },
    "pipelines": {
      "/pipelines": {
        "GET": {
          "description": "List CI/CD pipelines",
          "parameters": [
            "repo_id",
            "status",
            "trigger"
          ],
          "auth_required": "api_key",
          "auth_description": "Standard API access \u2014 available to all authenticated developers"
        },
        "POST": {
          "description": "Create pipeline",
          "parameters": [
            "repo_id",
            "name",
            "stages",
            "triggers",
            "config_yaml"
          ],
          "auth_required": "maintainer_key",
          "auth_description": "Maintainer access \u2014 repo owners and designated maintainers"
