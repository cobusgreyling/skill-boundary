      "/pipelines/{id}": {
        "GET": {
          "description": "Get pipeline details",
          "parameters": [],
          "auth_required": "api_key",
          "auth_description": "Standard API access \u2014 available to all authenticated developers"
        },
        "PATCH": {
          "description": "Update pipeline config",
          "parameters": [
            "stages",
            "triggers",
            "enabled"
          ],
          "auth_required": "maintainer_key",
          "auth_description": "Maintainer access \u2014 repo owners and designated maintainers"
        },
        "DELETE": {
          "description": "Delete pipeline",
          "parameters": [],
          "auth_required": "admin_key",
          "auth_description": "Admin access \u2014 platform administrators only"
        }
      },
      "/pipelines/{id}/runs": {
        "GET": {
          "description": "List pipeline runs",
          "parameters": [
            "status",
            "branch"
          ],
          "auth_required": "api_key",
          "auth_description": "Standard API access \u2014 available to all authenticated developers"
        },
        "POST": {
          "description": "Trigger pipeline run",
          "parameters": [
            "branch",
            "variables"
          ],
          "auth_required": "api_key",
          "auth_description": "Standard API access \u2014 available to all authenticated developers"
        }
      },
      "/pipelines/{id}/runs/{run_id}": {
        "GET": {
          "description": "Get pipeline run details and logs",
          "parameters": [],
          "auth_required": "api_key",
          "auth_description": "Standard API access \u2014 available to all authenticated developers"
        },
        "DELETE": {
          "description": "Cancel pipeline run",
          "parameters": [],
          "auth_required": "api_key",
          "auth_description": "Standard API access \u2014 available to all authenticated developers"
        }
      }
    },
